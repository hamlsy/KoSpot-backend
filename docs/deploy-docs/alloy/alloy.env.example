# Grafana Cloud remote_write endpoint.
# Example:
# GRAFANA_CLOUD_PROM_RW_URL=https://prometheus-prod-XX-prod-ap-northeast-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_RW_URL=

# Grafana Cloud Prometheus user ID (stack user).
GRAFANA_CLOUD_PROM_USER=

# Access Policy token with metrics:write scope.
GRAFANA_CLOUD_API_KEY=
